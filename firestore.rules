rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Incident cards — read-only from the frontend
    match /incidents/{incident} {
      allow read: if request.auth != null;
      // Only backend Cloud Functions can write (via Admin SDK, which bypasses rules)
      allow write: if false; 
    }

    // SOP chunks for RAG retrieval — read-only
    match /sopChunks/{chunk} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Events — the frontend writes demo events here
    match /events/{event} {
      allow read: if request.auth != null;
      // Validate required fields and constrain source to known enum values
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['source', 'zone', 'timestamp', 'raw'])
                    && request.resource.data.source in ['radio', 'sensor', 'cctv']
                    && request.resource.data.zone is string
                    && request.resource.data.zone.size() > 0
                    && request.resource.data.zone.size() <= 100;
      // Events are immutable once written
      allow update, delete: if false;
    }

    // Deny all access to any other collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
